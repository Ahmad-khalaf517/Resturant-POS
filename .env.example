
# Connect to Postgres using supabase connection string format
# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://[user].[PROJECT_ID]:[YOUR-PASSWORD]@aws-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://[user].[PROJECT_ID]:[YOUR-PASSWORD]@aws-[region].pooler.supabase.com:5432/postgres"
